// @version=6
strategy("EMA Trend Following Strategy (Long Only)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ============================================================================
// INPUT PARAMETERS
// ============================================================================

// EMA Length Inputs
EMA1_length = input.int(21, "EMA1 Length (Fast)", minval=1, group="EMA Settings")
EMA2_length = input.int(50, "EMA2 Length (Medium)", minval=1, group="EMA Settings")
EMA3_length = input.int(99, "EMA3 Length (Slow)", minval=1, group="EMA Settings")

// Volume Confirmation Input
volume_lookback = input.int(21, "Volume Lookback Period", minval=1, group="Volume Settings")

// Exit Condition Inputs
min_periods_before_ema_exit = input.int(5, "Min Periods Before EMA Exit", minval=1, group="Exit Settings")
max_bars_in_trade = input.int(50, "Max Bars in Trade", minval=1, group="Exit Settings")
stop_loss_percent = input.float(10.0, "Stop Loss %", minval=0.1, step=0.1, group="Exit Settings")

// ============================================================================
// CALCULATE INDICATORS
// ============================================================================

// Calculate the three EMAs
EMA1 = ta.ema(close, EMA1_length)
EMA2 = ta.ema(close, EMA2_length)
EMA3 = ta.ema(close, EMA3_length)

// Calculate median volume over the lookback period for Volume_Test
Volume_Test = ta.median(volume, volume_lookback)

// Volume confirmation: current volume must exceed median volume
volume_confirmed = volume > Volume_Test

// ============================================================================
// TREND DETECTION LOGIC
// ============================================================================

// Detect crossovers for EMA1 relative to EMA2 and EMA3
ema1_cross_over_ema2 = ta.crossover(EMA1, EMA2)
ema1_cross_over_ema3 = ta.crossover(EMA1, EMA3)

// Uptrend Signal: EMA1 crosses over one EMA while already above the other
// This triggers when EMA1 definitively moves above BOTH slower EMAs
uptrend_cross = (ema1_cross_over_ema2 and EMA1 > EMA3) or (ema1_cross_over_ema3 and EMA1 > EMA2)

// ============================================================================
// ENTRY SIGNAL WITH VOLUME CONFIRMATION
// ============================================================================

// Long entry: Uptrend confirmed with significant volume
long_entry = uptrend_cross and volume_confirmed

// ============================================================================
// POSITION TRACKING
// ============================================================================

// Track entry bar and price for long positions
var int long_entry_bar = na
var float long_entry_price = na

// Update tracking on long entry
if long_entry and strategy.position_size == 0
    long_entry_bar := bar_index
    long_entry_price := close

// Reset tracking when position is closed
if strategy.position_size == 0
    long_entry_bar := na
    long_entry_price := na

// ============================================================================
// EXIT CONDITIONS - LONG
// ============================================================================

// Calculate bars since long entry
bars_since_long_entry = bar_index - nz(long_entry_bar, bar_index)

// Condition 1: Price dropped below EMA1 after at least 5 periods
long_exit_ema = strategy.position_size > 0 and bars_since_long_entry >= min_periods_before_ema_exit and close < EMA1

// Condition 2: 50 candlesticks have elapsed since entry
long_exit_time = strategy.position_size > 0 and bars_since_long_entry >= max_bars_in_trade

// Condition 3: 10% stop loss triggered
long_stop_price = nz(long_entry_price, close) * (1 - stop_loss_percent / 100)
long_exit_stop = strategy.position_size > 0 and close <= long_stop_price

// Combined long exit (any condition triggers exit)
long_exit = long_exit_ema or long_exit_time or long_exit_stop

// ============================================================================
// STRATEGY EXECUTION
// ============================================================================

// Enter long position on confirmed uptrend
if long_entry
    strategy.entry("Long", strategy.long)

// Exit long position
if long_exit
    strategy.close("Long")

// ============================================================================
// VISUALIZATION
// ============================================================================

// Plot EMAs
plot(EMA1, "EMA1 (21)", color=color.new(color.blue, 0), linewidth=2)
plot(EMA2, "EMA2 (50)", color=color.new(color.orange, 0), linewidth=2)
plot(EMA3, "EMA3 (99)", color=color.new(color.red, 0), linewidth=2)

// Plot entry signal
plotshape(long_entry, "Long Entry", shape.triangleup, location.belowbar, color.new(color.green, 0), size=size.small)

// Plot exit signal
plotshape(long_exit and strategy.position_size > 0, "Long Exit", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny)

// Background color to show when in uptrend (EMA1 above both)
ema1_above_both = EMA1 > EMA2 and EMA1 > EMA3
bgcolor(ema1_above_both ? color.new(color.green, 90) : na)

// ============================================================================
// INFORMATION TABLE
// ============================================================================

var table info_table = table.new(position.top_right, 2, 7, bgcolor=color.new(color.gray, 80))

if barstate.islast
    table.cell(info_table, 0, 0, "Indicator", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "Value", text_color=color.white, text_size=size.small)

    table.cell(info_table, 0, 1, "EMA1 (Fast)", text_color=color.blue, text_size=size.small)
    table.cell(info_table, 1, 1, str.tostring(EMA1, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(info_table, 0, 2, "EMA2 (Medium)", text_color=color.orange, text_size=size.small)
    table.cell(info_table, 1, 2, str.tostring(EMA2, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(info_table, 0, 3, "EMA3 (Slow)", text_color=color.red, text_size=size.small)
    table.cell(info_table, 1, 3, str.tostring(EMA3, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(info_table, 0, 4, "Median Vol", text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 4, str.tostring(Volume_Test, "#.##"), text_color=volume_confirmed ? color.green : color.red, text_size=size.small)

    table.cell(info_table, 0, 5, "Position", text_color=color.white, text_size=size.small)
    pos_text = strategy.position_size > 0 ? "LONG" : "FLAT"
    pos_color = strategy.position_size > 0 ? color.green : color.gray
    table.cell(info_table, 1, 5, pos_text, text_color=pos_color, text_size=size.small)

    table.cell(info_table, 0, 6, "Bars in Trade", text_color=color.white, text_size=size.small)
    bars_in = strategy.position_size > 0 ? bars_since_long_entry : 0
    table.cell(info_table, 1, 6, str.tostring(bars_in), text_color=color.white, text_size=size.small)
