# =============================================================================
# Polymarket Trader — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -----------------------------------------------------------------------------
# Polymarket (https://polymarket.com — CLOB API credentials)
# -----------------------------------------------------------------------------
POLYMARKET_PRIVATE_KEY=          # Ed25519 private key for order signing
POLYMARKET_API_KEY=              # API key from Polymarket developer portal
POLYMARKET_API_SECRET=           # API secret for HMAC request signing
POLYMARKET_WALLET_ADDRESS=       # Your Polymarket wallet address (0x...)

# -----------------------------------------------------------------------------
# Kalshi (https://kalshi.com — trading account credentials)
# -----------------------------------------------------------------------------
KALSHI_EMAIL=                    # Kalshi account email
KALSHI_PASSWORD=                 # Kalshi account password
KALSHI_API_KEY=                  # Kalshi API key (optional, for enhanced access)

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
POSTGRES_URL=postgresql://user:password@localhost:5432/polymarket_trader
REDIS_URL=redis://localhost:6379/0
ALCHEMY_API_KEY=                 # Alchemy API key for Polygon RPC access

# -----------------------------------------------------------------------------
# Telegram (for Glint feed parsing)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=              # Bot token from @BotFather on Telegram
TELEGRAM_CHANNEL_ID=             # Numeric channel ID for Glint alerts

# -----------------------------------------------------------------------------
# Trading Configuration
# -----------------------------------------------------------------------------
INITIAL_BANKROLL=1000            # Starting bankroll in USD
MAX_DRAWDOWN_PCT=0.15            # Kill switch: halt at 15% 24h drawdown

# -----------------------------------------------------------------------------
# Optional — Phase 2+ (scraping sources)
# -----------------------------------------------------------------------------
HASHDIVE_SESSION_COOKIE=         # After manual login + cookie extraction from browser
ODDPOOL_SESSION_COOKIE=          # After manual login + cookie extraction from browser
