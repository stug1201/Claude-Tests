# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Pre-generated Telethon session string (run: python execution/generate_session.py)
TELEGRAM_SESSION_STRING=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Chat ID of the output channel/group where the brief will be sent
TELEGRAM_OUTPUT_CHAT_ID=

# Comma-separated list of source channel usernames (without @)
# Example: crypto_channel1,crypto_channel2,crypto_channel3,crypto_channel4
TELEGRAM_SOURCE_CHANNELS=

# Anthropic API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=
